# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
.venv/
venv/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
Desktop.ini

# Claude Code machine-local settings + harness worktrees
.claude/settings.local.json
.claude/worktrees/

# Cyberdeck runtime working dir — keep profile templates and
# plugin bundles, ignore everything else (logs, ejection snapshots,
# bootstrapped dispatcher script, construct work outputs).
cyberdeck-home/*
!cyberdeck-home/profiles/
!cyberdeck-home/plugins/

# Per-launch NDJSON log files (Phase 7 of the unified-event-stream
# slice). Operational artifacts; live next to the .py source so the
# brake hook protects them from constructs by default. Each launch
# creates `cyberdeck-YYYY-MM-DD-HHMMSS.log` plus a `latest.log`
# pointer. Local-only — keeping them out of git.
logs/
cyberdeck.log
ejected-*.json

# Milestone snapshots — history, not source.
Previous Versions/

# Image files
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.webp
*.ico
*.svg
