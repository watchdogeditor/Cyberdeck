# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
.venv/
venv/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
Desktop.ini

# Claude Code machine-local settings + harness worktrees
.claude/settings.local.json
.claude/worktrees/

# Cyberdeck runtime working dir — keep profile templates, ignore
# everything else (logs, ejection snapshots, bootstrapped dispatcher
# scripts, construct work outputs). Plugin bundles moved out of
# cyberdeck-home/plugins/ into <deck-source>/plugins/ in P2 of the
# tools/plugins/profiles retool (2026-05-03) — the brake hook's
# deck-source-write protection now extends to plugin code.
cyberdeck-home/*
!cyberdeck-home/profiles/

# Per-launch NDJSON log files (Phase 7 of the unified-event-stream
# slice). Operational artifacts; live next to the .py source so the
# brake hook protects them from constructs by default. Each launch
# creates `cyberdeck-YYYY-MM-DD-HHMMSS.log` plus a `latest.log`
# pointer. Local-only — keeping them out of git.
logs/
cyberdeck.log
ejected-*.json

# Role files (item 000 phase 2, 2026-05-11). Runtime-generated from
# bundled defaults in roles/_defaults.py on first launch — same
# pattern as profile_registry seeding default.toml. The `.md` files
# on disk are local netrunner calibration; the bundled defaults in
# code are the source of truth. Keep _defaults.py + __init__.py
# tracked, ignore the generated markdown + general.toml.
roles/*.md
roles/general.toml

# Milestone snapshots — history, not source.
Previous Versions/

# Image files
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.webp
*.ico
*.svg
